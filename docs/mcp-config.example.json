{
  "mcpServers": {
    "linuxdo-reader": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/kadaliao/linuxdo-reader",
        "linuxdo-reader-mcp"
      ],
      "env": {
        "LINUXDO_READER_DB": "/Users/you/.local/share/linuxdo-reader/linuxdo.sqlite"
      }
    }
  }
}
